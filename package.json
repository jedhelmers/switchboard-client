{
  "name": "@switchboard/client",
  "version": "0.2.6",
  "description": "TypeScript client + React Query hooks for the SwitchBoard chat platform's REST + WebSocket API.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./realtime": {
      "types": "./dist/realtime.d.ts",
      "import": "./dist/realtime.js"
    },
    "./api": {
      "types": "./dist/api/types.d.ts",
      "import": "./dist/api/types.js"
    },
    "./mrkdwn": {
      "types": "./dist/mrkdwn/index.d.ts",
      "import": "./dist/mrkdwn/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/mrkdwn/parser.test.ts",
    "gen:types": "openapi-typescript ../Stack/openapi/switchboard.v1.yaml -o src/api/types.ts"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "openapi-typescript": "^7.13.0",
    "react": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "sideEffects": false,
  "keywords": [
    "switchboard",
    "chat",
    "slack",
    "react",
    "websocket"
  ]
}
