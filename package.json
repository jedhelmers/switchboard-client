{
  "name": "@stack/client",
  "version": "0.1.0",
  "description": "TypeScript client + React Query hooks for the Stack chat platform's REST + WebSocket API.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks.ts",
      "import": "./src/hooks.ts"
    },
    "./realtime": {
      "types": "./src/realtime.ts",
      "import": "./src/realtime.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
      "./hooks": { "types": "./dist/hooks.d.ts", "import": "./dist/hooks.js" },
      "./realtime": { "types": "./dist/realtime.d.ts", "import": "./dist/realtime.js" }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "sideEffects": false,
  "keywords": [
    "stack",
    "chat",
    "slack",
    "react",
    "websocket"
  ]
}
